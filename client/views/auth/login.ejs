<%- include('../layouts/header-auth') %>

    <!-- MAIN: A classe login-container usa o Flexbox do Body para centralizar a div interna no meio do espaço livre -->
    <main class="login-container">
        <div class="auth-card">
            <div class="auth-card-header">
                <h1>CyberMonitoring</h1>
                <p>Faça login para acessar o painel de monitoramento</p>
            </div>

            <form action="/usuarios/login" method="POST" class="auth-form">
                <div class="form-group">
                    <label for="email_login">
                        E-mail
                    </label>
                    <input type="email" id="email_login" name="email" class="form-control" placeholder="Seu e-mail"
                        required>
                </div>

                <div class="form-group">
                    <label for="senha_login">
                        Senha
                    </label>
                    <input type="password" id="senha_login" name="senha" class="form-control"
                        placeholder="Mínimo 6 caracteres" required>
                </div>

                <button type="submit" class="btn btn-primary auth-button">
                    Entrar
                </button>

                <div class="auth-link-row">
                    <span>Novo?</span>
                    <a href="/cadastro">Cadastre-se</a>
                </div>
            </form>
            <section id="picture"
                class="w-0 lg:w-7/12 bg-[url('/img/background.png')] bg-cover rounded-r-3xl shadow-[inset_400px_30px_400px_-100px_theme('colors.zinc.950')] opacity-70">
            </section>
            </section>
        </div>
    </main>

    <%- include('../layouts/footer-auth') %>