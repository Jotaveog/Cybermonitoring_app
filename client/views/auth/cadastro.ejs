<!-- importa o header -->
<%- include('../partials/header')  %>

<main class="login-container">
    <div class="auth-card auth-card-wide">
        <div class="auth-card-header">
            <h1>Cadastro</h1>
            <p>Faça seu cadastro para acessar o painel de monitoramento</p>
        </div>

        <form action="/usuarios/cadastrar" method="post" class="auth-form">
            <div class="form-group">
                <label for="nome">
                    Nome completo
                </label>
                <input type="text" id="nome" name="nome" class="form-control" placeholder="Nome do usuário" required>
            </div>

            <div class="form-group">
                <label for="email">
                    E-mail
                </label>
                <input type="email" id="email" name="email" class="form-control" placeholder="Seu e-mail" required>
            </div>

            <!-- Caixinha de perfil -->
            <div class="form-group">
                <label for="perfil"> <i class="fa-solid fa-users"></i> Qual sua Função ?</label>
                    <select name="perfil" id="perfil" class="form-control" required>
                        <option value="administrador" style=" background-color: #12121A;"> Administrador </option>
                        <option value="tecnico" style="background-color: #12121A;"> Técnico </option>
                    </select>
            </div>

            <div class="form-group">
                <label for="senha">
                    Senha
                </label>
                <input type="password" id="senha" name="senha" class="form-control" placeholder="Mínimo 6 caracteres" required>
            </div>

            <div class="form-group">
                <label for="confirmar_senha">
                    Confirmar senha
                </label>
                <input type="password" id="confirmar_senha" name="confirmar_senha" class="form-control" placeholder="Confirme sua senha" required>
            </div>

            <button type="submit" class="btn btn-primary auth-button">
                Cadastrar
            </button>

            <div class="auth-link-row">
                <span>Já possui conta?</span>
                <a href="/login">Entrar</a>
            </div>
        </form>
    </div>
</main>