<%- include('../layouts/header') %>

<div class="main-content">
    <div class="container-fluid">
        <!-- TÍTULO E BREADCRUMB -->
        <div class="page-header">
            <div class="page-title">
                <h1>Gerenciar Computadores</h1>
                <p class="subtitle">Cadastro e edição de ativos</p>
            </div>
        </div>

        <!-- FORMULÁRIO CADASTRO/EDIÇÃO -->
        <div class="card card-form">
            <div class="card-header">
                <h5 class="card-title">Cadastrar/Editar Ativo</h5>
            </div>
            <div class="card-body">
                <form id="formAativo" class="row g-3">
                    <div class="col-md-6">
                        <label for="ip" class="form-label">IP</label>
                        <input type="text" class="form-control" id="ip" name="ip" placeholder="192.168.1.100">
                    </div>

                    <div class="col-md-6">
                        <label for="idComputador" class="form-label">ID do Computador</label>
                        <input type="text" class="form-control" id="idComputador" name="idComputador" placeholder="ID único">
                    </div>

                    <div class="col-md-6">
                        <label for="nomeMaquina" class="form-label">Nome da Máquina</label>
                        <input type="text" class="form-control" id="nomeMaquina" name="nomeMaquina" placeholder="Ex: PC-ADM-001">
                    </div>

                    <div class="col-md-6">
                        <label for="macAddress" class="form-label">MAC Address</label>
                        <input type="text" class="form-control" id="macAddress" name="macAddress" placeholder="00:1A:2B:3C:4D:5E">
                    </div>

                    <div class="col-md-6">
                        <label for="patrimonio" class="form-label">Patrimônio</label>
                        <input type="text" class="form-control" id="patrimonio" name="patrimonio" placeholder="Número do patrimônio">
                    </div>

                    <div class="col-md-6">
                        <label for="numeroSerie" class="form-label">Número de Série</label>
                        <input type="text" class="form-control" id="numeroSerie" name="numeroSerie" placeholder="Número de série">
                    </div>

                    <div class="col-md-6">
                        <label for="setor" class="form-label">Setor</label>
                        <input type="text" class="form-control" id="setor" name="setor" placeholder="Setor/Departamento">
                    </div>

                    <div class="col-md-6">
                        <label for="laboratorio" class="form-label">Laboratório</label>
                        <input type="text" class="form-control" id="laboratorio" name="laboratorio" placeholder="Lab/Sala">
                    </div>

                    <div class="col-md-6">
                        <label for="so" class="form-label">SO</label>
                        <select class="form-control" id="so" name="so">
                            <option value="">Selecione o SO</option>
                            <option value="Windows 11">Windows 11</option>
                            <option value="Windows 10">Windows 10</option>
                            <option value="Kali Linux 10.05">Kali Linux 10.05</option>
                            <option value="Ubuntu">Ubuntu</option>
                            <option value="macOS">macOS</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label for="observacoes" class="form-label">Observações</label>
                        <textarea class="form-control" id="observacoes" name="observacoes" rows="3" placeholder="Adicione observações adicionais..."></textarea>
                    </div>

                    <div class="col-12">
                        <div class="button-group">
                            <button type="submit" class="btn btn-primary btn-save">
                                <i class="fa-solid fa-floppy-disk"></i> Salvar Ativo
                            </button>
                            <button type="reset" class="btn btn-secondary btn-clear">
                                <i class="fa-solid fa-broom"></i> Limpar
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- SEÇÃO DE FILTROS E LISTA -->
        <div class="card card-list mt-4">
            <div class="card-header">
                <h5 class="card-title">Lista de ativos</h5>
            </div>
            <div class="card-body">
                <!-- FILTROS -->
                <div class="filters-section mb-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="filterStatus" class="form-label">Filtro de status</label>
                            <select class="form-control" id="filterStatus" name="filterStatus">
                                <option value="">Todos os status</option>
                                <option value="ativo">Ativo</option>
                                <option value="inativo">Inativo</option>
                                <option value="manutencao">Manutenção</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label for="filterSetor" class="form-label">Filtro de setor</label>
                            <select class="form-control" id="filterSetor" name="filterSetor">
                                <option value="">Todos os setores</option>
                                <option value="DDS">DDS</option>
                                <option value="CISCD">CISCD</option>
                                <option value="IPI">IPI</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- TABELA -->
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-header">
                            <tr>
                                <th>ID</th>
                                <th>Nome/IP</th>
                                <th>MAC</th>
                                <th>Setor</th>
                                <th>SO</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>DESKTOP-AIQBFPA</td>
                                <td>192.168.1.10</td>
                                <td>00:1A:2B:3C:4D:5E</td>
                                <td>DDS</td>
                                <td>Windows 11</td>
                                <td>
                                    <button class="btn btn-sm btn-danger btn-action" title="Editar">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger btn-action" title="Deletar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>

                            <tr>
                                <td>DESKTOP-AIQBRPL</td>
                                <td>192.168.1.20</td>
                                <td>00:1A:2B:3C:4D:5E</td>
                                <td>DDS</td>
                                <td>Windows 11</td>
                                <td>
                                    <button class="btn btn-sm btn-danger btn-action" title="Editar">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger btn-action" title="Deletar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>

                            <tr>
                                <td>DESKTOP-AIQBPPO</td>
                                <td>192.168.1.10</td>
                                <td>00:1A:2B:3C:4D:5E</td>
                                <td>CISCD</td>
                                <td>Kali Linux 10.05</td>
                                <td>
                                    <button class="btn btn-sm btn-danger btn-action" title="Editar">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger btn-action" title="Deletar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>

                            <tr>
                                <td>DESKTOP-AIQBFPA</td>
                                <td>192.168.1.10</td>
                                <td>00:1A:2B:3C:4D:5E</td>
                                <td>IPI</td>
                                <td>Windows 11</td>
                                <td>
                                    <button class="btn btn-sm btn-danger btn-action" title="Editar">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger btn-action" title="Deletar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
