<%- include('../layouts/header') %>

    <div class="main" id="reportsSection">
        <header class="page-header">
            <div>
                <h1>Relatórios</h1>
                <p>Exportação de dados</p>
            </div>
        </header>

        <div class="content-area">
            <div class="wide-card report-panel">
                <div class="report-panel-header">
                    <div>
                        <h3>Filtros do Relatório</h3>
                        <p>Veja os ativos e exporte apenas o que precisa.</p>
                    </div>
                </div>

                <div class="report-filter-row no-print">
                    <select id="reportSetor">
                        <option value="">Todos os setores</option>
                    </select>
                    <select id="reportStatus">
                        <option value="">Todos os status</option>
                        <option value="NORMAL">Normal</option>
                        <option value="ATENCAO">Atenção</option>
                        <option value="CRITICO">Crítico</option>
                    </select>
                    <input type="text" placeholder="Buscar..." id="searchReport">
                </div>

                <div class="report-actions no-print">
                    <button type="button" class="btn btn-primary" onclick="exportPDF()">PDF</button>
                    <button type="button" class="btn btn-primary" onclick="exportExcel()">Excel</button>
                    <button type="button" class="btn btn-secondary" onclick="printReport()">Imprimir</button>
                </div>
            </div>

            <div id="reportContent" class="wide-card report-summary-section">
                <div class="report-summary-grid">
                    <div class="summary-card report-metric-card">
                        <h3>Total</h3>
                        <p id="reportTotal" class="big-number green"><%= totalAtivos || 0 %></p>
                    </div>
                    <div class="summary-card report-metric-card">
                        <h3>Normal</h3>
                        <p id="reportNormal" class="big-number green"><%= onlineCount || 0 %></p>
                    </div>
                    <div class="summary-card report-metric-card">
                        <h3>Atenção</h3>
                        <p id="reportAtencao" class="big-number warning"><%= statusResumo.atencao || 0 %></p>
                    </div>
                    <div class="summary-card report-metric-card">
                        <h3>Crítico</h3>
                        <p id="reportCritico" class="big-number critical"><%= statusResumo.critico || 0 %></p>
                    </div>
                </div>

                <div class="table-responsive report-table-wrapper">
                    <table class="list-table-extended report-table" id="reportTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome / IP</th>
                                <th>MAC</th>
                                <th>Setor</th>
                                <th>Status</th>
                                <th>SO</th>
                                <th>Última atualização</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (ativos && ativos.length > 0) { %>
                                <% ativos.forEach(item => { %>
                                    <tr data-setor="<%= item.setor || '' %>" data-status="<%= item.status_monitoramento || '' %>" data-nome="<%= item.nome_maquina || '' %>" data-ip="<%= item.ip || '' %>">
                                        <td><%= item.patrimonio || item.id_ativo || item.nome_maquina || '-' %></td>
                                        <td><%= item.nome_maquina || '-' %><br><small><%= item.ip || '' %></small></td>
                                        <td><%= item.mac_address || item.mac || '-' %></td>
                                        <td><%= item.setor || '-' %></td>
                                        <td class="center-cell"><%- include('../layouts/status_chip', { status: item.status_monitoramento }) %></td>
                                        <td><%= item.sistema_operacional || item.so || '-' %></td>
                                        <td><%= item.ultima_atualizacao ? new Date(item.ultima_atualizacao).toLocaleString('pt-BR') : '-' %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr data-fallback="true"><td colspan="7" style="text-align:center; color:#999;">Nenhum ativo encontrado</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

           

    <script>
        window.reportSetores = <%- JSON.stringify(setores || []) %> || [];
    </script>
