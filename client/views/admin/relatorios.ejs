<%- include('../layouts/header') %>

    <div class="main" id="reportsSection">
        <header class="page-header">
            <div>
                <h1>Relatórios</h1>
                <p>Exportação de dados</p>
            </div>
        </header>

        <div class="content-area">
            <div class="wide-card report-panel">
                <div class="report-panel-header">
                    <div>
                        <h3>Filtros do Relatório</h3>
                        <p>Veja os ativos e exporte apenas o que precisa.</p>
                    </div>
                </div>

                <div class="report-filter-row no-print">
                    <select id="reportSetor">
                        <option value="">Todos os setores</option>
                    </select>
                    <select id="reportStatus">
                        <option value="">Todos os status</option>
                        <option value="NORMAL">Normal</option>
                        <option value="ATENCAO">Atenção</option>
                        <option value="CRITICO">Crítico</option>
                    </select>
                    <input type="text" placeholder="Buscar..." id="searchReport">
                </div>

                <div class="report-actions no-print">
                    <button type="button" class="btn btn-primary" onclick="exportPDF()">PDF</button>
                    <button type="button" class="btn btn-primary" onclick="exportExcel()">Excel</button>
                    <button type="button" class="btn btn-secondary" onclick="printReport()">Imprimir</button>
                </div>
            </div>

            <div id="reportContent" class="wide-card report-summary-section">
                <div class="report-summary-grid">
                    <div class="summary-card report-metric-card">
                        <h3>Total</h3>
                        <p id="reportTotal" class="big-number green"><%= totalAtivos || 0 %></p>
                    </div>
                    <div class="summary-card report-metric-card">
                        <h3>Normal</h3>
                        <p id="reportNormal" class="big-number green"><%= onlineCount || 0 %></p>
                    </div>
                    <div class="summary-card report-metric-card">
                        <h3>Atenção</h3>
                        <p id="reportAtencao" class="big-number warning"><%= statusResumo.atencao || 0 %></p>
                    </div>
                    <div class="summary-card report-metric-card">
                        <h3>Crítico</h3>
                        <p id="reportCritico" class="big-number critical"><%= statusResumo.critico || 0 %></p>
                    </div>
                </div>

                <div class="table-responsive report-table-wrapper">
                    <table class="list-table-extended report-table" id="reportTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome / IP</th>
                                <th>MAC</th>
                                <th>Setor</th>
                                <th>Status</th>
                                <th>SO</th>
                                <th>Última atualização</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (ativos && ativos.length > 0) { %>
                                <% ativos.forEach(item => { %>
                                    <tr data-setor="<%= item.setor || '' %>" data-status="<%= item.status_monitoramento || '' %>" data-nome="<%= item.nome_maquina || '' %>" data-ip="<%= item.ip || '' %>">
                                        <td><%= item.patrimonio || item.id_ativo || item.nome_maquina || '-' %></td>
                                        <td><%= item.nome_maquina || '-' %><br><small><%= item.ip || '' %></small></td>
                                        <td><%= item.mac_address || item.mac || '-' %></td>
                                        <td><%= item.setor || '-' %></td>
                                        <td class="center-cell"><%- include('../layouts/status_chip', { status: item.status_monitoramento }) %></td>
                                        <td><%= item.sistema_operacional || item.so || '-' %></td>
                                        <td><%= item.ultima_atualizacao ? new Date(item.ultima_atualizacao).toLocaleString('pt-BR') : '-' %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr data-fallback="true"><td colspan="7" style="text-align:center; color:#999;">Nenhum ativo encontrado</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

           

    <script>
        window.reportSetores = <%- JSON.stringify(setores || []) %> || [];
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const select = document.getElementById('reportSetor');
            if (!select) return;

            const existing = Array.from(select.querySelectorAll('option')).map(o => o.value).filter(v => v !== '');

            let setoresArr = Array.isArray(window.reportSetores) ? window.reportSetores.map(s => (s && s.nome) ? s.nome : s) : [];
            setoresArr = setoresArr.filter(Boolean);

            // Garantir setores específicos
            const required = ['CAC', 'CISCO', 'HTC-DDS-3-23'];
            required.forEach(r => { if (!setoresArr.includes(r) && !existing.includes(r)) setoresArr.push(r); });

            // Remover opções além da padrão e recriar na ordem desejada
            select.querySelectorAll('option:not([value=""])').forEach(o => o.remove());

            setoresArr.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                select.appendChild(opt);
            });
        });
    </script>

    <script>
        // Filtros do relatório: setor, status e busca
        document.addEventListener('DOMContentLoaded', () => {
            const setorSelect = document.getElementById('reportSetor');
            const statusSelect = document.getElementById('reportStatus');
            const searchInput = document.getElementById('searchReport');
            const table = document.getElementById('reportTable');
            const tbody = table ? table.querySelector('tbody') : null;
            const noResultsRow = tbody ? tbody.querySelector('tr[data-fallback]') : null;

            const elTotal = document.getElementById('reportTotal');
            const elNormal = document.getElementById('reportNormal');
            const elAtencao = document.getElementById('reportAtencao');
            const elCritico = document.getElementById('reportCritico');

            if (!tbody) return;

            function applyFilters() {
                const setor = setorSelect ? setorSelect.value.trim() : '';
                const status = statusSelect ? statusSelect.value.trim() : '';
                const term = searchInput ? searchInput.value.trim().toLowerCase() : '';

                const rows = Array.from(tbody.querySelectorAll('tr')).filter(r => !r.hasAttribute('data-fallback'));
                let visibleCount = 0;
                let normal = 0, atencao = 0, critico = 0;

                rows.forEach(row => {
                    const rowSetor = (row.getAttribute('data-setor') || '').trim();
                    const rowStatus = (row.getAttribute('data-status') || '').trim();
                    const text = row.textContent.toLowerCase();

                    let match = true;
                    if (setor) match = match && (rowSetor === setor);
                    if (status) match = match && (rowStatus === status);
                    if (term) match = match && text.includes(term);

                    if (match) {
                        row.style.display = '';
                        visibleCount++;
                        if (rowStatus === 'NORMAL') normal++;
                        else if (rowStatus === 'ATENCAO') atencao++;
                        else if (rowStatus === 'CRITICO') critico++;
                    } else {
                        row.style.display = 'none';
                    }
                });

                // show/hide fallback
                if (noResultsRow) noResultsRow.style.display = visibleCount === 0 ? '' : 'none';

                // atualizar contadores
                if (elTotal) elTotal.textContent = visibleCount;
                if (elNormal) elNormal.textContent = normal;
                if (elAtencao) elAtencao.textContent = atencao;
                if (elCritico) elCritico.textContent = critico;
            }

            if (setorSelect) setorSelect.addEventListener('change', applyFilters);
            if (statusSelect) statusSelect.addEventListener('change', applyFilters);
            if (searchInput) searchInput.addEventListener('input', applyFilters);

            // apply initial filters (in case selects were prefilled)
            applyFilters();
        });
    </script>
    <script src="/js/script.js" defer></script>
