<%- include('../layouts/header') %>

	<div class="main">
		<header>
			<div>
				<h1>Painel</h1>
				<p>Visão geral do sistema</p>
			</div>
		</header>

		<div class="content-area">
			<!-- CARDS RESUMO -->
			<div class="summary-grid">
				<!-- TOTAL DE ATIVOS -->
				<div class="summary-card">
					<h3>Total de ativos</h3>
					<p class="big-number">
						<%= totalAtivos %>
					</p>
				</div>

				<!-- STATUS DO ATIVO -->
				<div class="summary-card">
					<h3>Status do ativo</h3>
					<div class="chart-container">
						<div class="donut" id="dashboardPie" data-good="<%= otimo %>" data-warning="<%= atencao %>" data-critical="<%= critico %>"></div>
						<div class="legend">
							<span>Normal <strong id="countGood">
									<%= otimo %>
								</strong></span>
							<span>Atenção <strong id="countWarn">
									<%= atencao %>
								</strong></span>
							<span>Crítico <strong id="countCrit">
									<%= critico %>
								</strong></span>
						</div>
					</div>
				</div>

				<!-- ATIVOS POR SETOR -->
				<div class="summary-card">
					<h3>Ativos por setor</h3>
					<table class="list-table" style="font-size: 0.9rem;">
						<thead>
							<tr>
								<th style="color: #9dd1ff;">Setor</th>
								<th style="color: #9dd1ff;">Quantidade</th>
							</tr>
						</thead>
						<tbody>
							<% if (setores && setores.length> 0) { %>
								<% setores.forEach(s=> { %>
									<tr>
										<td>
											<%= s.nome %>
										</td>
										<td>
											<%= s.quantidade %>
										</td>
									</tr>
									<% }) %>
										<% } else { %>
											<tr>
												<td colspan="2" style="text-align: center;">Sem setores</td>
											</tr>
											<% } %>
						</tbody>
					</table>
				</div>
			</div>

			<!-- ÚLTIMOS EVENTOS -->
			<div class="wide-card">
				<h3>Últimos Eventos</h3>
				<table class="list-table-extended">
					<thead>
						<tr>
							<th>Data/Hora</th>
							<th>Host</th>
							<th>Informações</th>
							<th class="center-cell">Status</th>
						</tr>
					</thead>
					<tbody>
						<% if (eventos && eventos.length> 0) { %>
							<% eventos.forEach(ev=> { %>
								<tr>
									<td>
										<%= ev.dt %>
									</td>
									<td><strong>
											<%= ev.host %>
										</strong></td>
									<td>
										<%= ev.info %>
									</td>
									<td class="center-cell">
										<%- include('../layouts/status_chip', { status: ev.status }) %>
									</td>
								</tr>
								<% }) %>
									<% } else { %>
										<tr>
											<td colspan="4" style="text-align: center; color: #888;">Nenhum evento
												registrado</td>
										</tr>
										<% } %>
					</tbody>
				</table>
			</div>
		</div>
	</div>
	</div>

	<script src="/js/script.js" defer></script>

	<!-- SCRIPT PARA MARCAR LINK ATIVO NO MENU -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const navLinks = document.querySelectorAll('.sidebar nav a.nav-link');
			const currentPath = window.location.pathname;

			navLinks.forEach(link => {
				const href = link.getAttribute('href');
				// Remove classe active de todos
				link.classList.remove('active');
				// Verifica se a URL atual corresponde ao link
				if (currentPath === href || currentPath.startsWith(href + '/')) {
					link.classList.add('active');
				}
			});
		});
	</script>
	</body>

	</html>