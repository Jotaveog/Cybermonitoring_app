<%- include('../../layouts/header') %>

<main class="container-fluid" style="padding: 20px;">
    <div class="row">
        <div class="col-md-12">
            <h1 style="margin-bottom: 30px;">
                <i class="fa-solid fa-tools"></i> Dashboard Técnico
            </h1>
        </div>
    </div>

    <!-- Cards de Resumo -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fa-solid fa-desktop"></i> Ativos Monitorados
                    </h5>
                    <p class="card-text" style="font-size: 24px; font-weight: bold;">--</p>
                    <a href="/ativos" class="btn btn-sm btn-primary">Ver</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fa-solid fa-triangle-exclamation"></i> Problemas
                    </h5>
                    <p class="card-text" style="font-size: 24px; font-weight: bold; color: #dc3545;">--</p>
                    <a href="/monitoramentos" class="btn btn-sm btn-danger">Analisar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fa-solid fa-clock"></i> Última Sincronização
                    </h5>
                    <p class="card-text" style="font-size: 14px;">--</p>
                    <button class="btn btn-sm btn-success">Sincronizar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de Monitoramentos -->
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5>Histórico de Status (Últimas 24h)</h5>
                </div>
                <div class="card-body">
                    <canvas id="historyChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Status Atual</h5>
                </div>
                <div class="card-body">
                    <canvas id="statusPieChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela de Ativos -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Ativos Críticos e com Atenção</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Máquina</th>
                                <th>IP</th>
                                <th>Status</th>
                                <th>CPU</th>
                                <th>Memória</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="6" class="text-center text-muted">Carregando dados...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../../layouts/footer') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Placeholder para gráficos
    const historyCtx = document.getElementById('historyChart')?.getContext('2d');
    const pieCtx = document.getElementById('statusPieChart')?.getContext('2d');
    
    if (historyCtx) {
        new Chart(historyCtx, {
            type: 'line',
            data: {
                labels: [],
                datasets: [{
                    label: 'Status',
                    data: [],
                    borderColor: '#0066cc',
                    backgroundColor: 'rgba(0, 102, 204, 0.1)',
                    tension: 0.3
                }]
            }
        });
    }
    
    if (pieCtx) {
        new Chart(pieCtx, {
            type: 'doughnut',
            data: {
                labels: ['NORMAL', 'ATENÇÃO', 'CRÍTICO'],
                datasets: [{
                    data: [0, 0, 0],
                    backgroundColor: ['#28a745', '#ffc107', '#dc3545']
                }]
            }
        });
    }
</script>
