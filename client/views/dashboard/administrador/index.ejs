<%- include('../../layouts/header') %>

<main class="container-fluid" style="padding: 20px;">
    <div class="row">
        <div class="col-md-12">
            <h1 style="margin-bottom: 30px;">
                <i class="fa-solid fa-chart-line"></i> Dashboard Administrativo
            </h1>
        </div>
    </div>

    <!-- Cards de Resumo -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fa-solid fa-desktop"></i> Ativos
                    </h5>
                    <p class="card-text" style="font-size: 24px; font-weight: bold;">--</p>
                    <a href="/ativos" class="btn btn-sm btn-primary">Gerenciar</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fa-solid fa-users"></i> Usuários
                    </h5>
                    <p class="card-text" style="font-size: 24px; font-weight: bold;">--</p>
                    <a href="/usuarios" class="btn btn-sm btn-primary">Gerenciar</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fa-solid fa-triangle-exclamation"></i> Críticos
                    </h5>
                    <p class="card-text" style="font-size: 24px; font-weight: bold; color: #dc3545;">--</p>
                    <a href="/monitoramentos" class="btn btn-sm btn-danger">Ver</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="fa-solid fa-file-lines"></i> Relatórios
                    </h5>
                    <p class="card-text" style="font-size: 24px; font-weight: bold;">--</p>
                    <a href="/relatorios" class="btn btn-sm btn-primary">Ver</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficos e Dados -->
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Status dos Ativos</h5>
                </div>
                <div class="card-body">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Uso de Recursos</h5>
                </div>
                <div class="card-body">
                    <canvas id="resourceChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Logs Recentes -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Atividades Recentes</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Nenhuma atividade registrada</p>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../../layouts/footer') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Placeholder para gráficos - será preenchido com dados reais
    const statusCtx = document.getElementById('statusChart')?.getContext('2d');
    const resourceCtx = document.getElementById('resourceChart')?.getContext('2d');
    
    if (statusCtx) {
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['NORMAL', 'ATENÇÃO', 'CRÍTICO'],
                datasets: [{
                    data: [0, 0, 0],
                    backgroundColor: ['#28a745', '#ffc107', '#dc3545']
                }]
            }
        });
    }
</script>
