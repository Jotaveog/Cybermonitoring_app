<%- include('../layouts/header') %>

<div class="main">
	<header>
		<div>
			<h1>
				Gerenciar Usuários
			</h1>
			<p>
				Criar, editar e deletar usuários do sistema
			</p>
			
		</div>
	</header>


	<!-- FORMULÁRIO CADASTRO/EDIÇÃO -->
	<div class="card card-form">
		<div class="card-header">
			<h5 class="card-title" id="formTitle">Cadastrar/Editar Usuário</h5>
		</div>
		<div class="card-body">
			<form id="usuarioForm" action="/usuarios/cadastrar" method="POST" class="row g-3">
				<input type="hidden" id="usuarioId" name="usuario_id" value="">
				
				<div class="col-md-6">
					<label for="nome" class="form-label">Nome</label>
					<input type="text" class="form-control" id="nome" name="nome" placeholder="Insira seu Nome" required>
				</div>

				<div class="col-md-6">
					<label for="email" class="form-label">Email</label>
					<input type="email" class="form-control" id="email" name="email" placeholder="Digite seu email" required>
				</div>

				<div class="col-md-6">
					<label for="senha" class="form-label">Senha</label>
					<input type="password" class="form-control" id="senha" name="senha" placeholder="Mínimo 6 caracteres" required>
				</div>

				<div class="col-md-6">
					<label for="id_perfil" class="form-label">Role</label>
					<select name="id_perfil" class="form-control" id="id_perfil" required>
						<option value="">Selecione um role</option>
						<% if (perfis && perfis.length) { %>
							<% perfis.forEach(p => { %>
								<option value="<%= p.id_perfil %>"><%= p.nome_perfil %></option>
							<% }) %>
						<% } %>
					</select>
				</div>

				<div class="col-md-6">
					<label for="status" class="form-label">Status</label>
					<select name="status" class="form-control" id="status">
						<option value="ATIVO">Ativo</option>
						<option value="INATIVO">Inativo</option>
					</select>
				</div>

				<div class="col-12">
					<div class="button-group">
						<button type="submit" class="btn btn-primary btn-save" id="submitBtn">
							Salvar Usuário
						</button>
						<button type="button" class="btn btn-secondary btn-clear" id="cancelBtn" style="display:none;" onclick="limparFormulario()">
							Cancelar
						</button>
						<button type="button" class="btn btn-secondary btn-clear" id="limparBtn" onclick="limparFormulario()">
							Limpar
						</button>
					</div>
				</div>
			</form>
		</div>
	</div>

	<!-- SEÇÃO DE LISTA -->
	<div class="card card-list mt-4">
		<div class="card-header">
			<h5 class="card-title">Lista de Usuários</h5>
		</div>
		<div class="card-body">
			<div class="table-responsive">
				<table class="list-table-extended">
					<thead>
						<tr>
							<th>ID</th>
							<th>Nome</th>
							<th>Email</th>
							<th>Perfil</th>
							<th>Status</th>
							<th>Último Acesso</th>
							<th>Ações</th>
						</tr>
					</thead>
					<tbody>
						<% if (usuarios && usuarios.length > 0) { %>
							<% usuarios.forEach(usuario => { %>
								<tr>
									<td><%= usuario.id_usuario %></td>
									<td><strong><%= usuario.nome %></strong></td>
					<td><%= usuario.email %></td>
					<td>
						<span class="badge bg-info"><%= usuario.nome_perfil %></span>
					</td>
					<td>
						<% if (usuario.status === 'ATIVO') { %>
							<span class="status-ativo">ATIVO</span>
						<% } else { %>
							<span class="status-inativo">INATIVO</span>
						<% } %>
					</td>
					<td><%= usuario.ultimo_acesso ? new Date(usuario.ultimo_acesso).toLocaleString('pt-BR') : 'Nunca' %></td>
					<td>
						<button type="button" class="btn btn-sm btn-warning" onclick="carregarUsuarioParaEdicao(<%= usuario.id_usuario %>)">
							Editar
						</button>
						<form action="/usuarios/deletar/<%= usuario.id_usuario %>" method="POST" style="display: inline-block; margin-left: 8px;">
							<button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Tem certeza?')">
								Deletar
							</button>
						</form>
					</td>
								</tr>
							<% }); %>
						<% } else { %>
							<tr>
								<td colspan="7" class="text-center text-muted">Nenhum usuário cadastrado</td>
							</tr>
						<% } %>
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

<script src="/js/script.js" defer></script>
<script>
	// Função para carregar usuário para edição
	async function carregarUsuarioParaEdicao(usuarioId) {
		try {
			const response = await fetch(`/usuarios/api/dados/${usuarioId}`);
			if (!response.ok) {
				alert('Erro ao carregar dados do usuário');
				return;
			}

			const usuario = await response.json();

			// Preencher o formulário
			document.getElementById('usuarioId').value = usuario.id_usuario;
			document.getElementById('nome').value = usuario.nome;
			document.getElementById('email').value = usuario.email;
			document.getElementById('id_perfil').value = usuario.id_perfil;
			document.getElementById('status').value = usuario.status;
			document.getElementById('senha').value = '';
			document.getElementById('senha').placeholder = 'Deixe em branco para não alterar';
			document.getElementById('senha').required = false;

			// Modificar o formulário para modo de edição
			const form = document.getElementById('usuarioForm');
			form.action = `/usuarios/${usuarioId}/editar`;
			form.method = 'POST';

			// Mudar título e botão
			document.getElementById('formTitle').textContent = `Editando: ${usuario.nome}`;
			document.getElementById('submitBtn').innerHTML = 'Atualizar Usuário';
			document.getElementById('cancelBtn').style.display = 'inline-block';
			document.getElementById('limparBtn').textContent = 'Limpar';

			// Scroll para o formulário
			const formElement = document.getElementById('usuarioForm');
			formElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
		} catch (erro) {
			console.error('Erro:', erro);
			alert('Erro ao carregar dados do usuário');
		}
	}

	// Função para limpar o formulário e voltar ao modo de criação
	function limparFormulario() {
		const form = document.getElementById('usuarioForm');
		form.reset();
		document.getElementById('usuarioId').value = '';
		document.getElementById('senha').placeholder = 'Mínimo 6 caracteres';
		document.getElementById('senha').required = true;

		// Voltar ao modo de criação
		form.action = '/usuarios/cadastrar';
		form.method = 'POST';

		document.getElementById('formTitle').textContent = 'Cadastrar/Editar Usuário';
		document.getElementById('submitBtn').innerHTML = 'Salvar Usuário';
		document.getElementById('cancelBtn').style.display = 'none';
	}

	// Interceptar o submit do formulário
	document.getElementById('usuarioForm').addEventListener('submit', async function(e) {
		const usuarioId = document.getElementById('usuarioId').value;
		
		if (usuarioId) {
			// Modo edição - POST para /usuarios/:id/editar com todos os dados
			// O formulário já está configurado para fazer isso
			return true;
		}
		// Modo criação - deixar o formulário fazer o POST normal
		return true;
	});

	document.addEventListener('DOMContentLoaded', () => {
		const navLinks = document.querySelectorAll('.sidebar nav a.nav-link');
		const currentPath = window.location.pathname;

		navLinks.forEach(link => {
			const href = link.getAttribute('href');
			link.classList.remove('active');
			if (currentPath === href || currentPath.startsWith(href + '/')) {
				link.classList.add('active');
			}
		});
	});
</script>
</body>
</html>

