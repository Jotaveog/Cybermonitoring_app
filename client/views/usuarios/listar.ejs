<%- include('../layouts/header') %>

<div class="main">
	<header>
		<div>
			<h1>Gerenciar Usuários</h1>
			<p>Visão geral do sistema</p>
			<a href="/usuarios/cadastro" class="btn btn-primary mt-3">
				<i class="fa-solid fa-plus"></i> Novo Usuário
			</a>
		</div>
	</header>

	<div class="content-area">
		<div class="wide-card">
			<h3>Lista de Usuários</h3>
			<div style="border-collapse: separate; border-spacing: 0 10px;">
				<table class="list-table-extended" style="border-collapse: separate; border-spacing: 0 10px; width: 100%;">
					<thead>
						<tr>
							<th>ID</th>
							<th>Nome</th>
							<th>Email</th>
							<th>Perfil</th>
							<th>Status</th>
							<th>Último Acesso</th>
							<th>Ações</th>
						</tr>
					</thead>
					<tbody>
						<% if (usuarios && usuarios.length > 0) { %>
							<% usuarios.forEach(usuario => { %>
								<tr style="padding: 12px 0;">
									<td style="padding: 12px;"><%= usuario.id_usuario %></td>
									<td style="padding: 12px;"><%= usuario.nome %></td>
									<td style="padding: 12px;"><%= usuario.email %></td>
									<td style="padding: 12px;"><span class="badge bg-info"><%= usuario.nome_perfil %></span></td>
									<td style="padding: 12px;">
										<% if (usuario.status === 'ATIVO') { %>
											<span class="badge bg-success">ATIVO</span>
										<% } else { %>
											<span class="badge bg-danger">INATIVO</span>
										<% } %>
									</td>
									<td style="padding: 12px;"><%= usuario.ultimo_acesso ? new Date(usuario.ultimo_acesso).toLocaleString('pt-BR') : 'Nunca' %></td>
									<td style="padding: 12px;">
										<a href="/usuarios/<%= usuario.id_usuario %>/editar" class="btn btn-sm btn-warning">
											<i class="fa-solid fa-edit"></i>
										</a>
										<form action="/usuarios/deletar/<%= usuario.id_usuario %>" method="POST" style="display: inline;">
											<button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Tem certeza?')">
												<i class="fa-solid fa-trash"></i>
											</button>
										</form>
									</td>
								</tr>
							<% }); %>
						<% } else { %>
							<tr>
								<td colspan="7" class="text-center text-muted">Nenhum usuário cadastrado</td>
							</tr>
						<% } %>
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

<script src="/js/script.js" defer></script>
<script>
	document.addEventListener('DOMContentLoaded', () => {
		const navLinks = document.querySelectorAll('.sidebar nav a.nav-link');
		const currentPath = window.location.pathname;

		navLinks.forEach(link => {
			const href = link.getAttribute('href');
			link.classList.remove('active');
			if (currentPath === href || currentPath.startsWith(href + '/')) {
				link.classList.add('active');
			}
		});
	});
</script>
</body>
</html>

