<%- include('../layouts/header') %>

<main class="container-fluid user-management" style="padding:20px;">
  <div class="row mb-3">
    <div class="col-12">
      <h2>Gerenciar Usuários</h2>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-12">
      <div class="card summary-card">
        <h5>Cadastrar/Editar Usuário</h5>
        <form action="/usuarios/cadastrar" method="POST" class="row g-3 mt-2">
          <div class="col-md-4">
            <label class="form-label">Nome</label>
            <input name="nome" type="text" class="form-control form-control-sm" placeholder="Insira seu Nome" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control form-control-sm" placeholder="Digite seu email" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Role</label>
            <select name="id_perfil" class="form-control form-control-sm">
              <% if (perfis && perfis.length) { %>
                <% perfis.forEach(p => { %>
                  <option value="<%= p.id_perfil %>"><%= p.nome_perfil %></option>
                <% }) %>
              <% } %>
            </select>
          </div>

          <div class="col-md-4">
            <label class="form-label">Senha</label>
            <input name="senha" type="password" class="form-control form-control-sm" placeholder="Insira no mínimo 6 caracteres" required>
          </div>

          <div class="col-12 mt-2">
            <div style="width:100%;">
              <button class="btn auth-button" type="submit">Salvar Usuário</button>
            </div>
          </div>
          <div class="col-12 mt-2">
            <div style="display:flex; justify-content:flex-start;">
              <button type="reset" class="btn btn-secondary">Limpar</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-12">
      <div class="card wide-card">
        <h5>Lista de Usuários</h5>
        <div class="table-responsive mt-3">
          <%- include('listar_partial', { usuarios: usuarios || [] }) %>
        </div>
      </div>
    </div>
  </div>

</main>

