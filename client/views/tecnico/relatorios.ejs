<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Relatórios - Cybermonitoring</title>
		<link rel="stylesheet" href="/css/style.css" />
	</head>
	<body class="auth-page">
		<header class="header-sistema">
			<h2>CYBERMONITORING</h2>
			<nav class="nav-menu">
				<span>Técnico</span>
			</nav>
		</header>

		<main class="container dashboard-container">
			<aside class="sidebar">
				<div class="user-block">
					<div class="avatar">George</div>
					<div class="role">Técnico</div>
				</div>
				<ul class="menu">
					<li>Painel</li>
					<li>Gerenciar Computadores</li>
					<li class="active">Relatórios</li>
					<li>Histórico</li>
				</ul>
				<button class="btn logout">Sair</button>
			</aside>

			<section class="main-content">
				<div class="card" style="padding:24px;">
					<h2>Relatórios</h2>
					<p class="text-muted">Exportação de dados</p>
					<div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:18px; margin-top:22px;">
						<div>
							<label>Setor</label>
							<select class="form-control">
								<option>Todos os setores</option>
								<option>DDS</option>
								<option>IPI</option>
								<option>CISCO</option>
							</select>
						</div>
						<div>
							<label>Status</label>
							<select class="form-control">
								<option>Todos os status</option>
								<option>Online</option>
								<option>Atenção</option>
								<option>Crítico</option>
							</select>
						</div>
						<div>
							<label>Buscar</label>
							<input class="form-control" type="text" placeholder="Buscar..." />
						</div>
					</div>

					<div style="display:flex; gap:12px; margin-top:20px; flex-wrap:wrap;">
						<button class="btn" style="min-width:110px;">PDF</button>
						<button class="btn" style="min-width:110px;">Excel</button>
						<button class="btn" style="background:#292c34; border-color:#292c34; min-width:110px;">Imprimir</button>
					</div>
				</div>

				<div class="card" style="padding:24px; margin-top:18px;">
					<div style="display:flex; justify-content:space-between; align-items:center; gap:18px; flex-wrap:wrap;">
						<div>
							<h3>Relatórios de Ativos</h3>
							<p class="text-muted">Gerado em: <%= typeof dataGeracao !== 'undefined' ? dataGeracao : '09/04/2026, 14:42:56' %></p>
						</div>
					</div>

					<div style="display:grid; grid-template-columns:repeat(5, minmax(120px, 1fr)); gap:16px; margin-top:24px;">
						<div class="card" style="padding:18px; background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.12);">
							<p>Total</p>
							<div class="total-number" style="margin-top:12px;"><%= typeof totalAtivos !== 'undefined' ? totalAtivos : 7 %></div>
						</div>
						<div class="card" style="padding:18px; background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.12);">
							<p>Online</p>
							<div class="total-number" style="margin-top:12px;"><%= typeof online !== 'undefined' ? online : 4 %></div>
						</div>
						<div class="card" style="padding:18px; background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.12); text-align:center;">
							<p>Atenção</p>
							<div style="width:40px; height:40px; margin:10px auto; background:#f1c40f; border-radius:8px;"></div>
						</div>
						<div class="card" style="padding:18px; background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.12); text-align:center;">
							<p>Ótimo</p>
							<div style="width:40px; height:40px; margin:10px auto; background:#2ecc71; border-radius:8px;"></div>
						</div>
						<div class="card" style="padding:18px; background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.12); text-align:center;">
							<p>Crítico</p>
							<div style="width:40px; height:40px; margin:10px auto; background:#e74c3c; border-radius:8px;"></div>
						</div>
					</div>

					<table class="sector-table" style="width:100%; margin-top:24px;">
						<thead>
							<tr>
								<th>ID</th>
								<th>Nome</th>
								<th>MAC</th>
								<th>Setor</th>
								<th>Status</th>
								<th>SO</th>
								<th>Cadastro</th>
							</tr>
						</thead>
						<tbody>
							<% const relatorios = typeof relatorios !== 'undefined' ? relatorios : [
								{ id:'A80BPPL', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'DDS', status:'Crítico', statusColor:'#e74c3c', so:'Windows 11', cadastro:'Admin' },
								{ id:'A80BPPO', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'CISCO', status:'Ótimo', statusColor:'#2ecc71', so:'Kali Linux 1.0.05', cadastro:'TI_Suporte' },
								{ id:'A80BPPA', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'DDS', status:'Crítico', statusColor:'#e74c3c', so:'Windows 11', cadastro:'Admin' },
								{ id:'A80BPSA', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'IPO', status:'Atenção', statusColor:'#f1c40f', so:'Windows 11', cadastro:'TI_Suporte' }
							]; %>
							<% relatorios.forEach(item => { %>
								<tr>
									<td><%= item.id %></td>
									<td><%= item.nome %></td>
									<td><%= item.mac %></td>
									<td><%= item.setor %></td>
									<td>
										<div style="width:80px; height:16px; border-radius:999px; background:<%= item.statusColor %>">;</div>
									</td>
									<td><%= item.so %></td>
									<td><%= item.cadastro %></td>
								</tr>
							<% }) %>
						</tbody>
					</table>
				</div>
			</section>
		</main>

		<footer class="footer-sistema">
			<p>&copy; Cybermonitoring</p>
		</footer>
	</body>
</html>
