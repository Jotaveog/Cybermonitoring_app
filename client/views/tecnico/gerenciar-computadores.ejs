<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Gerenciar Computadores - Cybermonitoring</title>
		<link rel="stylesheet" href="/css/style.css" />
	</head>
	<body class="auth-page">
		<header class="header-sistema">
			<h2>CYBERMONITORING</h2>
			<nav class="nav-menu">
				<span>Técnico</span>
			</nav>
		</header>

		<main class="container dashboard-container">
			<aside class="sidebar">
				<div class="user-block">
					<div class="avatar">George</div>
					<div class="role">Técnico</div>
				</div>
				<ul class="menu">
					<li>Painel</li>
					<li class="active">Gerenciar Computadores</li>
					<li>Relatórios</li>
					<li>Histórico</li>
				</ul>
				<button class="btn logout">Sair</button>
			</aside>

			<section class="main-content">
				<div class="card" style="padding:24px;">
					<h2>Gerenciar Computadores</h2>
					<p class="text-muted">Cadastro e edição de ativos</p>
					<form action="/ativos/salvar" method="POST" style="display:grid; gap:18px; margin-top:24px;">
						<div style="display:grid; grid-template-columns:1fr 1fr; gap:18px;">
							<div style="display:grid; gap:14px;">
								<div>
									<label>IP</label>
									<input class="form-control" type="text" name="ip" placeholder="192.168.1.10" />
								</div>
								<div>
									<label>Nome da Máquina</label>
									<input class="form-control" type="text" name="nome_maquina" placeholder="DESKTOP-A80BPPA" />
								</div>
								<div>
									<label>Patrimônio</label>
									<input class="form-control" type="text" name="patrimonio" placeholder="SENAI" />
								</div>
								<div>
									<label>Setor</label>
									<input class="form-control" type="text" name="setor" placeholder="DDS-23" />
								</div>
								<div>
									<label>SO</label>
									<input class="form-control" type="text" name="so" placeholder="Windows 11" />
								</div>
								<div>
									<label>Observações</label>
									<input class="form-control" type="text" name="observacoes" placeholder="Máquina em funcionamento normal." />
								</div>
							</div>

							<div style="display:grid; gap:14px;">
								<div>
									<label>ID do Computador</label>
									<input class="form-control" type="text" name="id_computador" placeholder="DESKTOP-A80BPPA" />
								</div>
								<div>
									<label>MAC Address</label>
									<input class="form-control" type="text" name="mac" placeholder="00:1A:2B:3C:4D:5E" />
								</div>
								<div>
									<label>Número de Série</label>
									<input class="form-control" type="text" name="numero_serie" placeholder="310058413" />
								</div>
								<div>
									<label>Laboratório</label>
									<input class="form-control" type="text" name="laboratorio" placeholder="CISCO" />
								</div>
							</div>
						</div>

						<div style="display:flex; gap:14px; flex-wrap:wrap; margin-top:6px;">
							<button type="submit" class="btn" style="min-width:160px;">Salvar Ativo</button>
							<button type="reset" class="btn" style="background:#5a5f7a; border-color:#5a5f7a; min-width:140px;">Limpar</button>
						</div>
					</form>
				</div>

				<div class="card" style="padding:22px; margin-top:18px;">
					<h3>Filtros</h3>
					<div style="display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-top:16px;">
						<div>
							<select class="form-control" name="filtro_setor">
								<option>Todos os setores</option>
								<option>DDS</option>
								<option>IPI</option>
								<option>CISCO</option>
							</select>
						</div>
						<div>
							<select class="form-control" name="filtro_status">
								<option>Todos os status</option>
								<option>Normal</option>
								<option>Atenção</option>
								<option>Crítico</option>
							</select>
						</div>
					</div>
				</div>

				<div class="card" style="padding:22px; margin-top:18px;">
					<h3>Lista de ativos</h3>
					<table class="sector-table" style="width:100%; margin-top:16px;">
						<thead>
							<tr>
								<th>ID</th>
								<th>Nome/IP</th>
								<th>MAC</th>
								<th>Setor</th>
								<th>SO</th>
								<th style="text-align:right;">Ações</th>
							</tr>
						</thead>
						<tbody>
							<% const ativos = typeof ativos !== 'undefined' ? ativos : [
								{ id:'DESKTOP-A80BPPA', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'DDS', so:'Windows 11' },
								{ id:'DESKTOP-A80BPPL', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'DDS', so:'Windows 11' },
								{ id:'DESKTOP-A80BPPO', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'CISCO', so:'Kali Linux 1.0.05' },
								{ id:'DESKTOP-A80BPPA', nome:'192.168.1.10', mac:'00:1A:2B:3C:4D:5E', setor:'DDS', so:'Windows 11' }
							]; %>
							<% ativos.forEach(ativo => { %>
								<tr>
									<td><%= ativo.id %></td>
									<td><%= ativo.nome %></td>
									<td><%= ativo.mac %></td>
									<td><%= ativo.setor %></td>
									<td><%= ativo.so %></td>
									<td style="text-align:right;">
										<button class="btn" style="background:#e74c3c; border-color:#e74c3c; margin-right:8px;">Apagar</button>
										<button class="btn" style="background:#3a3f5d; border-color:#3a3f5d;">Editar</button>
									</td>
								</tr>
							<% }) %>
						</tbody>
					</table>
				</div>
			</section>
		</main>

		<footer class="footer-sistema">
			<p>&copy; Cybermonitoring</p>
		</footer>
	</body>
</html>
