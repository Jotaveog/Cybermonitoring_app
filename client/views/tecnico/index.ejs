<%- include('../partials/header') %>

<div class="container-fluid py-4">

    <!-- TÍTULO DA PÁGINA -->
    <div class="mb-4">
        <h2 style="color: var(--cor-destaque); font-weight: bold;">
            <i class="fa-solid fa-display"></i> Painel
        </h2>
        <small class="text-muted">Visão geral do sistema</small>
    </div>

    <!-- LINHA 1: Total de ativos + Status + Ativos por setor -->
    <div class="row g-4 mb-4">

        <!-- TOTAL DE ATIVOS -->
        <div class="col-md-3">
            <div class="card-cyber text-center p-4 h-100 d-flex flex-column justify-content-center align-items-center">
                <p class="card-cyber-label mb-2">Total de ativos</p>
                <span class="numero-destaque"><%= totalAtivos %></span>
            </div>
        </div>

        <!-- STATUS DO ATIVO -->
        <div class="col-md-4">
            <div class="card-cyber p-4 h-100">
                <p class="card-cyber-label mb-3">Status do ativo</p>

                <div class="d-flex justify-content-center mb-3">
                    <canvas id="statusChart" width="150" height="150"></canvas>
                </div>

                <ul class="list-unstyled mb-0">
                    <li class="d-flex justify-content-between align-items-center mb-2">
                        <span>
                            <i class="fa-solid fa-circle me-2" style="color: #4caf50;"></i>
                            Online
                        </span>
                        <strong style="color: #4caf50;"><%= status.online %></strong>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-2">
                        <span>
                            <i class="fa-solid fa-circle me-2" style="color: #f5c542;"></i>
                            Atenção
                        </span>
                        <strong style="color: #f5c542;"><%= status.atencao %></strong>
                    </li>
                    <li class="d-flex justify-content-between align-items-center">
                        <span>
                            <i class="fa-solid fa-circle me-2" style="color: #e74c3c;"></i>
                            Crítico
                        </span>
                        <strong style="color: #e74c3c;"><%= status.critico %></strong>
                    </li>
                </ul>
            </div>
        </div>

        <!-- ATIVOS POR SETOR -->
        <div class="col-md-5">
            <div class="card-cyber p-4 h-100">
                <p class="card-cyber-label mb-3">Ativos por setor</p>
                <table class="table table-dark table-borderless mb-0">
                    <thead>
                        <tr style="border-bottom: 1px solid #444;">
                            <th>Setor</th>
                            <th class="text-end">Quantidade</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% setores.forEach(function(setor) { %>
                        <tr style="border-bottom: 1px solid #333;">
                            <td><%= setor.nome %></td>
                            <td class="text-end fw-bold <%= setor.quantidade === 0 ? 'text-muted' : '' %>">
                                <%= setor.quantidade %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- LINHA 2: ÚLTIMOS EVENTOS -->
    <div class="row">
        <div class="col-12">
            <div class="card-cyber p-4">
                <p class="card-cyber-label mb-3">
                    <i class="fa-solid fa-clock-rotate-left me-2"></i>Últimos Eventos
                </p>
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0">
                        <thead>
                            <tr style="border-bottom: 1px solid #444;">
                                <th>Data/Hora</th>
                                <th>Hostname</th>
                                <th class="text-end">Disco</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% eventos.forEach(function(evento) { %>
                            <tr>
                                <td class="text-muted" style="font-family: monospace; font-size: 13px;">
                                    <%= evento.data %>
                                </td>
                                <td class="fw-bold"><%= evento.hostname %></td>

                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- BOOTSTRAP JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReKnzrbZBFerBMVoSiMdJl1HrXnbXk"
    crossorigin="anonymous"></script>

<!-- GRÁFICO DE PIZZA -->
<script>
    (function () {
        const canvas = document.getElementById('statusChart');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');

        const total = dados.online + dados.atencao + dados.critico;
        const fatias = [
            { valor: dados.online,  cor: '#4caf50' },
            { valor: dados.atencao, cor: '#f5c542' },
            { valor: dados.critico, cor: '#e74c3c' },
        ].filter(f => f.valor > 0);

        const cx = canvas.width / 2, cy = canvas.height / 2;
        const raio = Math.min(cx, cy) - 6;
        let angulo = -Math.PI / 2;

        fatias.forEach(function (f) {
            const arco = (f.valor / total) * 2 * Math.PI;
            ctx.beginPath();
            ctx.moveTo(cx, cy);
            ctx.arc(cx, cy, raio, angulo, angulo + arco);
            ctx.closePath();
            ctx.fillStyle = f.cor;
            ctx.fill();
            angulo += arco;
        });

        // Furo central (efeito donut)
        ctx.beginPath();
        ctx.arc(cx, cy, raio * 0.48, 0, 2 * Math.PI);
        ctx.fillStyle = getComputedStyle(document.body).getPropertyValue('--cor-fundo') || '#1a1a1f';
        ctx.fill();
    })();
</script>

</body>
</html>
