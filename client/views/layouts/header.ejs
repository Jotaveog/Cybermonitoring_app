<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CyberMonitoring</title>

    <!-- IMPORTAÇÃO FONT AWESOME -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- IMPORTAÇÃO DO BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous" />

    <!-- IMPORTAÇÃO DO CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <!-- SE TIVER LOGADO - EXIBE SIDEBAR -->
    <% if (typeof usuario !=='undefined' && usuario) { %>
        <!-- SIDEBAR LATERAL -->
        <aside class="sidebar">
            <!-- LOGO/TÍTULO -->
            <div class="sidebar-header">
                <span class="logo-text">CYBERMONITORING</span>
            </div>

            <!-- DADOS DO USUÁRIO -->
            <div class="user-info">
                <% if (usuario.foto) { %>
                    <img src="/uploads/usuarios/<%= usuario.foto %>" alt="<%= usuario.nome %>" class="user-avatar">
                <% } else { %>
                    <div class="user-avatar-placeholder">
                        <i class="fa-solid fa-user"></i>
                    </div>
                <% } %>
                <div class="user-details">
                    <p class="user-name"><%= usuario.nome %></p>
                    <p class="user-role"><%= usuario.perfil %></p>
                </div>
            </div>

            <!-- MENU NAVEGAÇÃO -->
            <nav class="sidebar-nav">
                <!-- MENU ADMINISTRADOR -->
                <% if (usuario.perfil === 'Administrador') { %>
                    <a href="/dashboard/admin" class="nav-item">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Painel</span>
                    </a>
                    <a href="/gerenciar-computadores" class="nav-item">
                        <i class="fa-solid fa-computer"></i>
                        <span>Gerenciar Computadores</span>
                    </a>
                    <a href="/usuarios" class="nav-item">
                        <i class="fa-solid fa-users"></i>
                        <span>Gerenciar Usuários</span>
                    </a>
                    <a href="/configuracoes" class="nav-item">
                        <i class="fa-solid fa-gear"></i>
                        <span>Configurações</span>
                    </a>
                    <a href="/relatorios" class="nav-item">
                        <i class="fa-solid fa-file-chart-line"></i>
                        <span>Relatórios</span>
                    </a>
                    <a href="/historico" class="nav-item">
                        <i class="fa-solid fa-history"></i>
                        <span>Histórico</span>
                    </a>
                <% } %>

                <!-- MENU TÉCNICO -->
                <% if (usuario.perfil === 'Tecnico') { %>
                    <a href="/dashboard/tecnico" class="nav-item">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Painel</span>
                    </a>
                    <a href="/monitoramentos" class="nav-item">
                        <i class="fa-solid fa-wifi"></i>
                        <span>Monitoramentos</span>
                    </a>
                    <a href="/ativos" class="nav-item">
                        <i class="fa-solid fa-server"></i>
                        <span>Ativos</span>
                    </a>
                    <a href="/relatorios" class="nav-item">
                        <i class="fa-solid fa-file-chart-line"></i>
                        <span>Relatórios</span>
                    </a>
                <% } %>
            </nav>

            <!-- BOTÃO SAIR -->
            <div class="sidebar-footer">
                <a href="/usuarios/logout" class="btn-logout">
                    <i class="fa-solid fa-sign-out-alt"></i>
                    <span>Sair</span>
                </a>
            </div>
        </aside>

        <!-- CONTEÚDO PRINCIPAL -->
        <div class="main-wrapper">
    <% } %>
